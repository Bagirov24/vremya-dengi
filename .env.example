# ============================================
# Vremya-Dengi Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# App
APP_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=20

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...
STRIPE_BIZ_MONTHLY_PRICE_ID=price_...
STRIPE_BIZ_YEARLY_PRICE_ID=price_...

# Resend (Email)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:ABC-...
TELEGRAM_WEBHOOK_SECRET=random-secret
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/api/telegram/webhook

# Web Push (VAPID)
VAPID_PUBLIC_KEY=BHx...
VAPID_PRIVATE_KEY=abc...
VAPID_CLAIMS_EMAIL=mailto:admin@yourdomain.com

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Encryption (for broker API tokens)
ENCRYPTION_KEY=your-fernet-key

# AI Categorization
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_API_KEY=sk-...
AI_MODEL=gpt-4o-mini

# MOEX (no key needed)
# Finam
FINAM_API_TOKEN=your-finam-token

# Tinkoff Invest
TINKOFF_API_TOKEN=your-tinkoff-token

# Cron
CRON_SECRET=your-cron-secret
