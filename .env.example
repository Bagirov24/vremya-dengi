# ==========================================
# Vremya-Dengi Environment Configuration
# Copy this file to .env and fill in your values
# ==========================================

# App
APP_ENV=development
APP_NAME=Vremya-Dengi
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# PostgreSQL
POSTGRES_DB=vremya_dengi
POSTGRES_USER=vd_user
POSTGRES_PASSWORD=vd_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://vd_user:vd_password@db:5432/vremya_dengi

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=20

# JWT Auth
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...

# Resend (Email)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@vremya-dengi.ru

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=Vremya-Dengi
